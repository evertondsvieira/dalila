{
  "name": "dalila",
  "version": "1.10.2",
  "description": "DOM-first reactive framework based on signals",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "dalila-dev": "./scripts/dev-server.cjs",
    "dalila": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/scope": {
      "types": "./dist/core/scope.d.ts",
      "default": "./dist/core/scope.js"
    },
    "./core/signal": {
      "types": "./dist/core/signal.d.ts",
      "default": "./dist/core/signal.js"
    },
    "./core/observability": {
      "types": "./dist/core/observability.d.ts",
      "default": "./dist/core/observability.js"
    },
    "./core/watch": {
      "types": "./dist/core/watch.d.ts",
      "default": "./dist/core/watch.js"
    },
    "./core/when": {
      "types": "./dist/core/when.d.ts",
      "default": "./dist/core/when.js"
    },
    "./core/match": {
      "types": "./dist/core/match.d.ts",
      "default": "./dist/core/match.js"
    },
    "./core/for": {
      "types": "./dist/core/for.d.ts",
      "default": "./dist/core/for.js"
    },
    "./core/html": {
      "types": "./dist/core/html.d.ts",
      "default": "./dist/core/html.js"
    },
    "./core/dev": {
      "types": "./dist/core/dev.d.ts",
      "default": "./dist/core/dev.js"
    },
    "./core/key": {
      "types": "./dist/core/key.d.ts",
      "default": "./dist/core/key.js"
    },
    "./core/resource": {
      "types": "./dist/core/resource.d.ts",
      "default": "./dist/core/resource.js"
    },
    "./core/query": {
      "types": "./dist/core/query.d.ts",
      "default": "./dist/core/query.js"
    },
    "./core/mutation": {
      "types": "./dist/core/mutation.d.ts",
      "default": "./dist/core/mutation.js"
    },
    "./core/scheduler": {
      "types": "./dist/core/scheduler.d.ts",
      "default": "./dist/core/scheduler.js"
    },
    "./core/persist": {
      "types": "./dist/core/persist.d.ts",
      "default": "./dist/core/persist.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "default": "./dist/context/index.js"
    },
    "./context/raw": {
      "types": "./dist/context/raw.d.ts",
      "default": "./dist/context/raw.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime/bind": {
      "types": "./dist/runtime/bind.d.ts",
      "default": "./dist/runtime/bind.js"
    },
    "./runtime/component": {
      "types": "./dist/runtime/component.d.ts",
      "default": "./dist/runtime/component.js"
    },
    "./runtime/lazy": {
      "types": "./dist/runtime/lazy.d.ts",
      "default": "./dist/runtime/lazy.js"
    },
    "./runtime/boundary": {
      "types": "./dist/runtime/boundary.d.ts",
      "default": "./dist/runtime/boundary.js"
    },
    "./runtime/from-html": {
      "types": "./dist/runtime/fromHtml.d.ts",
      "default": "./dist/runtime/fromHtml.js"
    },
    "./runtime/html-sinks": {
      "types": "./dist/runtime/html-sinks.d.ts",
      "default": "./dist/runtime/html-sinks.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "default": "./dist/form/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./components/ui": {
      "types": "./dist/components/ui/index.d.ts",
      "default": "./dist/components/ui/index.js"
    },
    "./components/ui/dialog": {
      "types": "./dist/components/ui/dialog/index.d.ts",
      "default": "./dist/components/ui/dialog/index.js"
    },
    "./components/ui/drawer": {
      "types": "./dist/components/ui/drawer/index.d.ts",
      "default": "./dist/components/ui/drawer/index.js"
    },
    "./components/ui/popover": {
      "types": "./dist/components/ui/popover/index.d.ts",
      "default": "./dist/components/ui/popover/index.js"
    },
    "./components/ui/dropdown": {
      "types": "./dist/components/ui/dropdown/index.d.ts",
      "default": "./dist/components/ui/dropdown/index.js"
    },
    "./components/ui/combobox": {
      "types": "./dist/components/ui/combobox/index.d.ts",
      "default": "./dist/components/ui/combobox/index.js"
    },
    "./components/ui/accordion": {
      "types": "./dist/components/ui/accordion/index.d.ts",
      "default": "./dist/components/ui/accordion/index.js"
    },
    "./components/ui/tabs": {
      "types": "./dist/components/ui/tabs/index.d.ts",
      "default": "./dist/components/ui/tabs/index.js"
    },
    "./components/ui/calendar": {
      "types": "./dist/components/ui/calendar/index.d.ts",
      "default": "./dist/components/ui/calendar/index.js"
    },
    "./components/ui/toast": {
      "types": "./dist/components/ui/toast/index.d.ts",
      "default": "./dist/components/ui/toast/index.js"
    },
    "./components/ui/dropzone": {
      "types": "./dist/components/ui/dropzone/index.d.ts",
      "default": "./dist/components/ui/dropzone/index.js"
    },
    "./components/ui/runtime": {
      "types": "./dist/components/ui/runtime.d.ts",
      "default": "./dist/components/ui/runtime.js"
    },
    "./components/ui/env": {
      "types": "./dist/components/ui/env.d.ts",
      "default": "./dist/components/ui/env.js"
    },
    "./components/ui/*/*.css": "./src/components/ui/*/*.css"
  },
  "sideEffects": [
    "./src/components/ui/*/*.css"
  ],
  "scripts": {
    "build": "tsc && node scripts/ensure-cli-executable.cjs",
    "dev": "tsc --watch",
    "serve": "node scripts/dev-server.cjs",
    "test:unit": "npm run build && node scripts/run-unit-tests.cjs",
    "test": "npm run test:unit --",
    "test:coverage": "npm run build && node --experimental-test-coverage --experimental-strip-types --test --test-concurrency=1 tests/**/*.test.ts",
    "test:typecheck": "npx tsc -p tests/tsconfig.json",
    "test:e2e": "npm run build && playwright test",
    "test:smoke:examples": "npm run build && playwright test e2e/examples-smoke.spec.ts",
    "security:audit": "npm audit --audit-level=high",
    "security:sbom": "npm sbom --sbom-format cyclonedx > sbom.cdx.json",
    "security:ci": "npm run security:audit && npm run security:sbom",
    "test:watch": "npm run build && node --watch --experimental-strip-types --test --test-concurrency=1 tests/**/*.test.ts",
    "clean": "rm -rf dist",
    "devtools:firefox:run": "npx web-ext run --source-dir devtools-extension --devtools",
    "devtools:firefox:build": "npx web-ext build --source-dir devtools-extension --artifacts-dir devtools-extension/dist --overwrite-dest"
  },
  "keywords": [
    "framework",
    "reactive",
    "signals",
    "dom",
    "typescript",
    "spa"
  ],
  "author": "Everton Da Silva Vieira",
  "license": "MIT",
  "engines": {
    "node": ">=22.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20.0.0",
    "chokidar": "^3.6.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "src/components/ui/*/*.css",
    "scripts/dev-server.cjs",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evertondsvieira/dalila.git"
  },
  "bugs": {
    "url": "https://github.com/evertondsvieira/dalila/issues"
  },
  "homepage": "https://github.com/evertondsvieira/dalila/blob/main/README.md"
}
