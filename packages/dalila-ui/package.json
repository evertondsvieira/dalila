{
  "name": "dalila-ui",
  "version": "1.10.5",
  "description": "Opinionated UI components for Dalila",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "default": "./dist/dialog/index.js"
    },
    "./drawer": {
      "types": "./dist/drawer/index.d.ts",
      "default": "./dist/drawer/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "default": "./dist/popover/index.js"
    },
    "./dropdown": {
      "types": "./dist/dropdown/index.d.ts",
      "default": "./dist/dropdown/index.js"
    },
    "./combobox": {
      "types": "./dist/combobox/index.d.ts",
      "default": "./dist/combobox/index.js"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "default": "./dist/accordion/index.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "default": "./dist/tabs/index.js"
    },
    "./calendar": {
      "types": "./dist/calendar/index.d.ts",
      "default": "./dist/calendar/index.js"
    },
    "./toast": {
      "types": "./dist/toast/index.d.ts",
      "default": "./dist/toast/index.js"
    },
    "./dropzone": {
      "types": "./dist/dropzone/index.d.ts",
      "default": "./dist/dropzone/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./*/*.css": "./src/*/*.css"
  },
  "sideEffects": [
    "./src/*/*.css"
  ],
  "files": [
    "dist",
    "src/*/*.css",
    "README.md"
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "peerDependencies": {
    "dalila": "^1.10.5"
  }
}
